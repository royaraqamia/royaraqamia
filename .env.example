# Base URL for the site (used in sitemap generation)
# Defaults to https://royaraqamia.com if not set
# For local development, use: http://localhost:3000
NEXT_PUBLIC_BASE_URL=https://royaraqamia.com

# WhatsApp phone number for contact links
# Defaults to the business line if not set
NEXT_PUBLIC_WHATSAPP_PHONE=963968478904

# Sentry DSN for error tracking (optional — errors are silently caught without it)
# Get yours at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
